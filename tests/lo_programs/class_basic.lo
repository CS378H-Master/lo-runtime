// class_basic.lo — WS-1 smoke fixture. Grammar-corrected to LO-3 by SC, 2026-05-29.
// Expected stdout: "7" + newline (tests/expected/class_basic.out). main() returns 0.
// Exercises: one user class with a method — allocation, the implicit constructor
// (its parameter list matches the field list), method dispatch, and integer output.

class Box ( int value; ) {
    int get() {
        return value;
    }
}

class Main ( ) {
    int main() {
        Box b;
        b = new Box(7);
        out.print_int(b.get());
        out.println();
        return 0;
    }
}
