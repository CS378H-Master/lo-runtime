// class_basic.lo — shared smoke fixture.
//
// Surface syntax validated against planning:lo-3-reference.md (three-section
// class decl: fields in `( )`, constructors in `[ ]`, methods in `{ }`).
// Stable contract: expected/class_basic.out (`7`).
//
// Intent: declare one class with methods, instantiate it, mutate and read via
// dispatch, and print the result — exercising allocation, method dispatch, and
// output. `Box` declares an explicit zero-arg constructor so `new Box()` is
// well-formed (a bare field section would give only a one-arg implicit
// constructor, making `new Box()` an arity error).

class Box ( int value; ) [
    Box() {
        value = 0;
    }
] {
    int get() {
        return value;
    }

    void set(int v) {
        value = v;
    }
}

class Main ( ) {
    int main() {
        Box b;
        b = new Box();
        b.set(7);
        out.print_int(b.get());
        out.println();
        return 0;
    }
}
