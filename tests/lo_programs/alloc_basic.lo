// alloc_basic.lo — shared smoke fixture.
//
// Surface syntax validated against planning:lo-3-reference.md (redesigned LO-3:
// three-section class decl; `int Main.main()` entry; pre-bound `out`; snake_case
// IO methods). Stable contract: expected/alloc_basic.out (`42`).
//
// Intent: exercise the allocator (the entry wrapper allocates `new Main()` via
// lo_alloc) and the integer-output path.

class Main ( ) {
    int main() {
        int n;
        n = 42;
        out.print_int(n);
        out.println();
        return 0;
    }
}
