# clang-tidy checks for the LO runtime C++ skeleton.
#
# A runtime allocator/ABI layer is inherently low-level: it does pointer
# arithmetic, reinterpret_casts between byte buffers and object headers, and
# C-linkage stubs that throw. We enable the high-value families (bugprone,
# performance, portability, most of readability/modernize) and disable the
# checks that fundamentally fight this domain.
Checks: >
  clang-analyzer-*,
  bugprone-*,
  performance-*,
  portability-*,
  modernize-*,
  readability-*,
  -modernize-use-trailing-return-type,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-function-cognitive-complexity,
  -bugprone-easily-swappable-parameters,
  -modernize-use-nodiscard,
  -portability-avoid-pragma-once,
  -readability-implicit-bool-conversion
WarningsAsErrors: ''
HeaderFilterRegex: 'lo_runtime/.*'
